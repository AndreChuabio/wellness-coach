# Wellness Coach AI - Environment Variables
# Copy this to .env and fill in your keys

# Shared password for the deployed app. Frontend prompts for this once and
# stores it in localStorage; backend rejects requests without a matching
# X-App-Password header. Pick something only you and Nikki know.
APP_PASSWORD=change_me

# Claude API (required for context generation)
ANTHROPIC_API_KEY=your_anthropic_key_here

# Tavus CVI (required for live video avatar)
# Get these from: https://platform.tavus.io
TAVUS_API_KEY=your_tavus_key_here
TAVUS_REPLICA_ID=your_replica_id_here    # The avatar/character
TAVUS_PERSONA_ID=your_persona_id_here    # The persona/voice

# ElevenLabs — voiceover narration for video briefing
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# AIML API — Kling video generation (get key at aimlapi.com)
AIMLAPI_KEY=your_aimlapi_key_here

# ── Google Calendar ──────────────────────────────────────────────────────────
# Two paths supported:
#
# 1) Local dev: run `python3 setup_gcal.py --user andre` and
#    `python3 setup_gcal.py --user nikki`. They produce token_andre.pickle
#    and token_nikki.pickle next to credentials.json. The backend will look
#    for token_<user>.pickle automatically — no path env vars needed for
#    local dev as long as the project root is the cwd.
#
# 2) Railway: paste the raw credentials.json content as GOOGLE_CREDENTIALS_JSON
#    and the base64-encoded token files as GOOGLE_TOKEN_PICKLE_B64_<USER>.
#    The backend materializes them to /tmp at startup. setup_gcal.py prints
#    the base64 for you after a successful run.

GOOGLE_CREDENTIALS_PATH=../credentials.json
# GOOGLE_CREDENTIALS_JSON='{...your credentials.json content...}'
# GOOGLE_TOKEN_PICKLE_B64_ANDRE='...base64 of token_andre.pickle...'
# GOOGLE_TOKEN_PICKLE_B64_NIKKI='...base64 of token_nikki.pickle...'
